# Copy to `.env.local` and fill in (Expo auto-loads it; it's gitignored).
#
# Google Maps SDK for Android key — get one in Google Cloud Console
# (enable "Maps SDK for Android", restrict the key to this app's package +
# signing SHA-1). iOS uses Apple Maps and needs no key. Without this, the
# Android map shows a blank/gray base layer.
GOOGLE_MAPS_KEY=

# Sentry crash/error reporting.
# SENTRY_DSN  — the project DSN (Sentry > Project > Settings > Client Keys).
#               Surfaced to the app via app.config.js `extra.sentryDsn`.
# SENTRY_ORG / SENTRY_PROJECT — slugs (NOT the numeric IDs); only needed for
#               native source-map upload at build time. When both are set the
#               @sentry/react-native plugin is enabled.
# SENTRY_AUTH_TOKEN — build-time token for source-map upload (Sentry > Settings
#               > Auth Tokens, scope: project:releases). Keep it out of git.
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
