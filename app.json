{
  "expo": {
    "name": "Baltic72",
    "slug": "baltic72",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "baltic72",
    "userInterfaceStyle": "automatic",
    "description": "Offline-first civil safety app for the Baltic states.",
    "ios": {
      "supportsTablet": true,
      "buildNumber": "13",
      "associatedDomains": [
        "applinks:baltic72.com"
      ],
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Baltic72 uses your location to show the nearest shelters while you use the map."
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": []
      },
      "bundleIdentifier": "com.baltic72.app"
    },
    "android": {
      "versionCode": 7,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#1B4D8C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "autoVerify": true,
          "action": "VIEW",
          "data": {
            "scheme": "https",
            "host": "baltic72.com",
            "pathPrefix": "/join"
          },
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "allowBackup": false,
      "predictiveBackGestureEnabled": false,
      "package": "com.baltic72.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "name": "Baltic72",
      "shortName": "Baltic72",
      "lang": "en",
      "scope": "/",
      "startUrl": "/en",
      "display": "standalone",
      "themeColor": "#1B4D8C",
      "backgroundColor": "#F8FAFC",
      "preferRelatedApplications": true,
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFC"
        }
      ],
      "expo-sqlite",
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#1B4D8C",
          "defaultChannel": "emergency-alerts"
        }
      ],
      [
        "expo-maps",
        {
          "requestLocationPermission": true,
          "locationPermission": "Baltic72 uses your location to show nearby shelters on the map."
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Baltic72 uses the camera to scan a family invite QR code.",
          "recordAudioAndroid": false
        }
      ]
    ],
    "newArchEnabled": false,
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "shelterUpdateUrl": "https://api.baltic72.com/shelters/manifest",
      "familyApiUrl": "https://api.baltic72.com"
    }
  }
}
